<Window x:Class="QuanLyChiTieu.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:QuanLyChiTieu.Converters"
        Title="Quản lý chi tiêu trọ" Height="600" Width="850"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <conv:DuongDanAnhToBitmapConverter x:Key="AnhConverter"/>
    </Window.Resources>


    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Tiêu đề -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="🏠" FontSize="26" Margin="0,0,10,0"/>
            <StackPanel>
                <TextBlock Text="Quản lý chi tiêu trọ" FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource MauChuChinh}"/>
                <TextBlock Text="3 người · Tháng 7/2026" FontSize="12.5"
                           Foreground="{StaticResource MauChuPhu}"/>
            </StackPanel>
        </StackPanel>

        <!-- Form nhập -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.3*"/>
                    <!-- Mặt hàng -->
                    <ColumnDefinition Width="1*"/>
                    <!-- Số tiền -->
                    <ColumnDefinition Width="1.4*"/>
                    <!-- Người trả -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Nút Thêm -->
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Text="MẶT HÀNG" Style="{StaticResource NhanChu}"/>
                    <TextBox Style="{StaticResource TextBoxChinh}"
                     Text="{Binding TenMatHang, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                    <TextBlock Text="SỐ TIỀN" Style="{StaticResource NhanChu}"/>
                    <TextBox Style="{StaticResource TextBoxChinh}" FontSize="15"
                     Text="{Binding SoTienNhap, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Grid.Column="3">
                    <TextBlock Text=" " Style="{StaticResource NhanChu}"/>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="38" Height="38" CornerRadius="6" Margin="0,0,8,0"
                                BorderBrush="{StaticResource MauVien}" BorderThickness="1"
                                Background="White" ClipToBounds="True">
                            <Image Source="{Binding DuongDanAnhTamThoi, Converter={StaticResource AnhConverter}}"
                                   Stretch="UniformToFill"/>
                        </Border>

                        <Button Content="📎" Command="{Binding ChonAnhCommand}"
                                Width="38" Height="38" FontSize="16" Margin="0,0,8,0"
                                Style="{StaticResource ButtonChinh}"
                                Background="{StaticResource MauChuPhu}"
                                ToolTip="Đính kèm ảnh hóa đơn"/>

                        <Button Content="+ Thêm" Style="{StaticResource ButtonChinh}"
                                Command="{Binding ThemCommand}"
                                FontSize="15" Padding="24,10" Height="38"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Danh sách -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0,0,0,16">
            <DataGrid Style="{StaticResource DataGridChinh}"
              ItemsSource="{Binding DanhSachKhoanChi}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="NGÀY" Width="90"
                                 Binding="{Binding NgayMua, StringFormat=dd/MM/yyyy}"/>
                    <DataGridTextColumn Header="MẶT HÀNG" Width="*"
                                 Binding="{Binding TenMatHang}"/>
                    <DataGridTextColumn Header="NGƯỜI TRẢ" Width="120"
                                 Binding="{Binding NguoiTra.Ten}"/>
                    <DataGridTextColumn Header="SỐ TIỀN" Width="120"
                                 Binding="{Binding SoTien, StringFormat={}{0:N0} đ}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Tổng kết -->
        <Border Grid.Row="3" Style="{StaticResource CardStyle}" Background="{StaticResource MauChinhNhat}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="Tổng chi tháng này: " FontSize="15"
                   Foreground="{StaticResource MauChuPhu}" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding TongChiThang, StringFormat={}{0:N0} đ}" FontSize="18" FontWeight="Bold"
                   Foreground="{StaticResource MauChinhDam}" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>